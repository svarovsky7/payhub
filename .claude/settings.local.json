{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(mkdir:*)",
      "Bash(npm install)",
      "Bash(npm run build:*)",
      "Bash(timeout 10 npm run dev)",
      "Bash(npm run lint)",
      "Bash(rm:*)",
      "Bash(npm run dev:*)",
      "Bash(mv:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm run:*)"
    ],
    "deny": []
  }
}